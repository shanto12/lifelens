# LifeLens server-side environment (Netlify Functions only — never exposed to the client)

# --- AI providers ---
# Z.ai GLM Coding Plan key (primary provider: insights, alternatives research)
GLM_API_KEY=
# Optional overrides
GLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
GLM_MODEL=glm-5.2
# xAI Grok key (secondary provider: call scripts / persona-tone drafting)
XAI_API_KEY=

# --- Data store (owner mode) ---
SUPABASE_URL=
# Public anon key (RLS denies everything without the gate secret below)
SUPABASE_ANON_KEY=
# Server-side gate secret sent as x-lifelens-key; RLS policies only open for requests carrying it
SUPABASE_API_SECRET=

# --- Owner access ---
# Access code that unlocks the real (owner) snapshot instead of the synthetic persona
LIFELENS_ACCESS_CODE=

# --- Telephony (optional; call features run in dry-run mode without these) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
OWNER_PHONE_NUMBER=

# --- Connectors (optional; Connections screen shows the catalog without these) ---
# Composio API key — managed per-user OAuth to 100s of apps (composio.dev)
COMPOSIO_API_KEY=
# JSON map of toolkit slug -> Composio auth config id (created in the Composio dashboard)
# e.g. {"github":"ac_xxx","slack":"ac_yyy","notion":"ac_zzz"}
COMPOSIO_AUTH_CONFIGS=
# Optional overrides
COMPOSIO_BASE_URL=https://backend.composio.dev/api/v3
COMPOSIO_USER_ID=lifelens-owner
